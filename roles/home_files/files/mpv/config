profile=high-quality

hwdec=auto
#vo=gpu
vo=gpu-next

video-sync=display-resample
interpolation

autofit=65%x65%

sub-bold=yes
sub-back-color=000000/0.4
sub-border-style=background-box
sub-font-size=36
sub-border-size=0.0
sub-shadow-offset=5
sub-color='#FFFFFF'

#sub-ass-override=force
sub-ass-override=strip

alang=jpn,eng
slang=eng

cache=yes
demuxer-max-bytes=128MiB

glsl-shaders="~/.config/mpv/adaptive-sharpen-luma.glsl"
